# --- Dashboard server ------------------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8088
DASHBOARD_DB=dashboard.db
# Optional basic auth untuk akses dashboard. Format "user:pass". Kosong = open.
DASHBOARD_BASIC_AUTH=

# --- Upstream WhatsApp REST API (core go-whatsapp-web-multidevice) ---------
# Arahkan ke server REST yang sedang jalan (`cd src && go run . rest`).
WHATSAPP_API_URL=http://localhost:3000
# Kalau core API pakai basic auth (APP_BASIC_AUTH), isi credential di sini juga.
WHATSAPP_API_USER=
WHATSAPP_API_PASSWORD=

# --- Default timezone untuk schedule baru ----------------------------------
# Boleh "Local", "UTC", atau IANA tz name (mis. "Asia/Jakarta").
DASHBOARD_TZ=Asia/Jakarta
